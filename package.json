{
  "name": "agent-battle",
  "version": "0.0.1",
  "description": "Turn-based AI agent battle simulator over WebSockets",
  "main": "server/index.ts",
  "scripts": {
    "dev": "bun --watch server/index.ts",
    "build": "bun build server/index.ts --outdir dist --target bun",
    "start": "bun server/index.ts",
    "agent": "bun client/agent.ts"
  },
  "dependencies": {
    "@openrouter/ai-sdk-provider": "^2.3.1",
    "ai": "^6.0.116",
    "express": "^5.2.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "bun-types": "latest",
    "typescript": "^5.9.3"
  }
}
